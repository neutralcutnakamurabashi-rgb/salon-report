# Googleサービスアカウントの認証情報（JSONファイル）
GOOGLE_SERVICE_ACCOUNT_KEY=./config/service-account.json

# GoogleスプレッドシートのID（URLの /d/〇〇〇/edit の〇〇〇部分）
SPREADSHEET_ID=your-spreadsheet-id-here

# Anthropic API キー（AIコメント生成用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# LINE Messaging API チャネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# LINE送信先グループID（または全スタッフのユーザーIDをカンマ区切り）
LINE_GROUP_ID=your-line-group-id

# Surge（画像の公開URL化）
SURGE_LOGIN=your-email@example.com
SURGE_TOKEN=your-surge-token
SURGE_DOMAIN=salon-report-images.surge.sh
